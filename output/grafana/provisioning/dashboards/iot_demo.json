      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('$__interval', time) AS time, device_id AS metric, AVG(value) AS value FROM sensor_data WHERE metric = 'cpu_temp' AND device_id != 'raspi' AND $__timeFilter(time) GROUP BY 1, device_id ORDER BY 1",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 2,
      "title": "Mensajes recibidos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM sensor_data WHERE $__timeFilter(time)",
          "format": "table"
        }
      ]
    },

    {
      "id": 3,
      "title": "Intervalo promedio entre mensajes (s)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (MAX(time) - MIN(time))) / NULLIF(COUNT(*) - 1, 0)) FROM sensor_data WHERE $__timeFilter(time)",
          "format": "table"
        }
      ]
    },

    {
      "id": 4,
      "title": "Dispositivos activos (últ. 5 min)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT device_id) FROM sensor_data WHERE time > NOW() - INTERVAL '5 minutes'",
          "format": "table"
        }
      ]
    },

